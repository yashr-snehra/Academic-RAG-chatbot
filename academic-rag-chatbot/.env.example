# ── LLM (local, via Ollama — no API key needed) ───────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768          # must match the embedding model's output size
LLM_TEMPERATURE=0.0
# Adaptive answer-length budget (tokens) — computed continuously per question.
LLM_NUM_PREDICT_MIN=128
LLM_NUM_PREDICT_MAX=1536
LLM_NUM_PREDICT_PER_WORD=24
LLM_KEEP_ALIVE=30m
LLM_REQUEST_TIMEOUT=120

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=academic_docs

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600
SESSION_TTL_SECONDS=86400

# ── Retrieval tuning ──────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=4
CHUNK_SIZE=700
CHUNK_OVERLAP=100
